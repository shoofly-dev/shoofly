#!/usr/bin/env bash
# shoofly-notify — Shoofly notification dispatcher
# Usage: shoofly-notify <channel> "<message>"
# License: MIT

CHANNEL="${1:-}"
MSG="${2:-}"
CONFIG="$HOME/.shoofly/config.json"
ENV_FILE="$HOME/.shoofly/.env"

[[ -z "$CHANNEL" ]] && { echo "Usage: shoofly-notify <channel|--all> <message>" >&2; exit 1; }
[[ -z "$MSG" ]] && { echo "Usage: shoofly-notify <channel|--all> <message>" >&2; exit 1; }

# --all mode: read notification_channels from config and send to each
if [[ "$CHANNEL" == "--all" ]]; then
  if [[ ! -f "$CONFIG" ]]; then
    echo "Error: config not found at $CONFIG" >&2; exit 1
  fi
  CHANNELS=$(jq -r '.notification_channels[]' "$CONFIG" 2>/dev/null)
  [[ -z "$CHANNELS" ]] && { echo "Error: no notification_channels in config" >&2; exit 1; }
  for ch in $CHANNELS; do
    "$0" "$ch" "$MSG"
  done
  exit 0
fi

# Source credentials if available (Telegram tokens, etc.)
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

case "$CHANNEL" in
  telegram)
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      -d "chat_id=${TELEGRAM_CHAT_ID}" \
      -d "text=${MSG}" > /dev/null
    ;;
  whatsapp)
    command -v wacli >/dev/null && wacli send --to "$(jq -r .whatsapp_number "$CONFIG")" --message "$MSG"
    ;;
  openclaw_gateway)
    OPENCLAW_BIN=$(command -v openclaw 2>/dev/null || echo "/opt/homebrew/bin/openclaw")
    CHAT_ID=$(jq -r '.telegram_chat_id // ""' "$CONFIG" 2>/dev/null || echo "")
    if [[ -n "$CHAT_ID" ]]; then
      "$OPENCLAW_BIN" message send --channel telegram --target "$CHAT_ID" --message "$MSG" > /dev/null 2>&1 || \
      "$OPENCLAW_BIN" system event --text "$MSG" --mode now > /dev/null 2>&1
    else
      "$OPENCLAW_BIN" system event --text "$MSG" --mode now > /dev/null 2>&1
    fi
    ;;
  terminal)
    echo "$MSG" >&2
    ;;
  macos)
    osascript -e "display notification \"$MSG\" with title \"Shoofly ⚡🪰⚡\" sound name \"Basso\""
    ;;
  *)
    echo "Unknown channel: $CHANNEL" >&2
    exit 1
    ;;
esac

# Always log notification dispatch to alerts.log
echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"channel\":\"$CHANNEL\",\"msg\":\"$MSG\"}" \
  >> "$HOME/.shoofly/logs/alerts.log"
