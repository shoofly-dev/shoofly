#!/usr/bin/env bash
# shoofly-policy-lint — Validate a shoofly.yaml custom policy file
#
# Usage:
#   shoofly-policy-lint [path/to/shoofly.yaml]
#
# If no path is given, looks for ./shoofly.yaml then ~/.shoofly/shoofly.yaml.
#
# Exit codes:
#   0 = valid
#   1 = invalid (details on stdout/stderr)
#
# License: MIT

set -euo pipefail

SHOOFLY_DIR="$HOME/.shoofly"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Locate parse-policy.py ───────────────────────────────────────────────────
# Try installed path first, then relative to this script (dev layout)
PARSE_SCRIPT="$SHOOFLY_DIR/lib/parse-policy.py"
if [[ ! -f "$PARSE_SCRIPT" ]]; then
  PARSE_SCRIPT="${SCRIPT_DIR}/../lib/parse-policy.py"
fi
if [[ ! -f "$PARSE_SCRIPT" ]]; then
  echo "ERROR: parse-policy.py not found." >&2
  echo "       Is Shoofly installed? Expected: $SHOOFLY_DIR/lib/parse-policy.py" >&2
  exit 1
fi

# ─── Check python3 ────────────────────────────────────────────────────────────
if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required but not found in PATH." >&2
  exit 1
fi

# ─── Locate policy file ───────────────────────────────────────────────────────
if [[ $# -ge 1 ]]; then
  POLICY_FILE="$1"
else
  if [[ -f "./shoofly.yaml" ]]; then
    POLICY_FILE="./shoofly.yaml"
  elif [[ -f "$SHOOFLY_DIR/shoofly.yaml" ]]; then
    POLICY_FILE="$SHOOFLY_DIR/shoofly.yaml"
  else
    echo "ERROR: No shoofly.yaml found." >&2
    echo "       Specify a path or place shoofly.yaml in the current directory." >&2
    exit 1
  fi
fi

if [[ ! -f "$POLICY_FILE" ]]; then
  echo "ERROR: File not found: $POLICY_FILE" >&2
  exit 1
fi

echo "Linting: $POLICY_FILE"
echo ""

# ─── Run parser ───────────────────────────────────────────────────────────────
PARSE_ERR_TMP="$(mktemp /tmp/shoofly-lint-XXXXXX)"
# shellcheck disable=SC2064
trap "rm -f '$PARSE_ERR_TMP'" EXIT

if ! PARSE_OUTPUT="$(python3 "$PARSE_SCRIPT" "$POLICY_FILE" 2>"$PARSE_ERR_TMP")"; then
  echo "INVALID: Parse failed"
  if [[ -s "$PARSE_ERR_TMP" ]]; then
    echo ""
    echo "Errors:"
    cat "$PARSE_ERR_TMP" >&2
  fi
  exit 1
fi

# Print any warnings from stderr
if [[ -s "$PARSE_ERR_TMP" ]]; then
  echo "Warnings:"
  cat "$PARSE_ERR_TMP"
  echo ""
fi

# ─── Validate output ──────────────────────────────────────────────────────────
if ! command -v jq >/dev/null 2>&1; then
  echo "VALID: (jq not available — skipping field validation)"
  echo ""
  echo "Parsed output:"
  echo "$PARSE_OUTPUT"
  exit 0
fi

VERSION="$(echo "$PARSE_OUTPUT" | jq -r '.version // "?"' 2>/dev/null || echo "?")"
RULE_COUNT="$(echo "$PARSE_OUTPUT" | jq '.rules | length' 2>/dev/null || echo 0)"

echo "Version:  $VERSION"
echo "Rules:    $RULE_COUNT"
echo ""

ERRORS=0
for (( i = 0; i < RULE_COUNT; i++ )); do
  rule_id="$(echo "$PARSE_OUTPUT" | jq -r ".rules[$i].id // \"\"" 2>/dev/null || echo "")"
  if [[ -z "$rule_id" ]]; then
    echo "  ERROR: Rule $i is missing required field 'id'"
    (( ERRORS++ )) || true
    continue
  fi

  rule_name="$(echo "$PARSE_OUTPUT" | jq -r ".rules[$i].name // \"(unnamed)\"" 2>/dev/null || echo "(unnamed)")"
  do_log="$(echo "$PARSE_OUTPUT" | jq -r ".rules[$i].log" 2>/dev/null || echo "false")"
  do_block="$(echo "$PARSE_OUTPUT" | jq -r ".rules[$i].block" 2>/dev/null || echo "false")"
  detect_count="$(echo "$PARSE_OUTPUT" | jq "
    .rules[$i].detect |
    (.url_contains | length) +
    (.text_contains | length) +
    (.path_matches | length) +
    (if .action != null then 1 else 0 end)
  " 2>/dev/null || echo 0)"
  has_alert="$(echo "$PARSE_OUTPUT" | jq -r ".rules[$i].alert != null" 2>/dev/null || echo "false")"

  echo "  [$i] $rule_id"
  echo "       name:   $rule_name"
  echo "       detect: $detect_count condition(s)   log: $do_log   block: $do_block   alert: $has_alert"
done

echo ""
if [[ "$ERRORS" -gt 0 ]]; then
  echo "INVALID: $ERRORS error(s) found"
  exit 1
else
  echo "VALID: $RULE_COUNT rule(s) parsed successfully"
  exit 0
fi
