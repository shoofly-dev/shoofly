#!/usr/bin/env bash
# Usage: shoofly-notify <channel> "<message>"
CHANNEL="$1"
RAW_MSG="$2"
MSG="$(printf 'в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\nрџ›ЎпёЏ  SHOOFLY ALERT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n%s\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ' "$RAW_MSG")"
CONFIG="$HOME/.shoofly/config.json"

# Read credentials from config.json (never source .env as shell вЂ” F4)
TELEGRAM_BOT_TOKEN=$(jq -r '.telegram_bot_token // ""' "$CONFIG" 2>/dev/null || echo "")
TELEGRAM_CHAT_ID=$(jq -r '.telegram_chat_id // ""' "$CONFIG" 2>/dev/null || echo "")

# Pre-encode for safe interpolation (F2)
JSON_MSG=$(printf '%s' "$MSG" | jq -Rs .)
SAFE_OSA_MSG=$(printf '%s' "$MSG" | sed 's/\\/\\\\/g; s/"/\\"/g')

case "$CHANNEL" in
  telegram)
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      --data-urlencode "chat_id=${TELEGRAM_CHAT_ID}" \
      --data-urlencode "text=${MSG}" > /dev/null
    ;;
  whatsapp)
    command -v wacli >/dev/null && wacli send --to "$(jq -r .whatsapp_number "$CONFIG")" --message "$MSG"
    ;;
  openclaw_gateway)
    curl -s -X POST http://127.0.0.1:18789/chat \
      -H "Content-Type: application/json" \
      -d "{\"message\": $JSON_MSG}" > /dev/null
    ;;
  terminal)
    echo "$MSG" >&2
    ;;
  macos)
    osascript -e "display notification \"$SAFE_OSA_MSG\" with title \"Shoofly рџЄ°\" sound name \"Basso\""
    ;;
esac

# Always log
jq -n -c --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg channel "$CHANNEL" --arg msg "$MSG" \
  '{ts:$ts,channel:$channel,msg:$msg}' >> "$HOME/.shoofly/logs/alerts.log"
