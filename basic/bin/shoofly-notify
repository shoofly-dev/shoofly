#!/usr/bin/env bash
# Usage: shoofly-notify <channel> "<message>"
CHANNEL="$1"
RAW_MSG="$2"
CONFIG="$HOME/.shoofly/config.json"

[[ -z "$CHANNEL" ]] && { echo "Usage: shoofly-notify <channel|--all> <message>" >&2; exit 1; }
[[ -z "$RAW_MSG" ]] && { echo "Usage: shoofly-notify <channel|--all> <message>" >&2; exit 1; }

# --all mode: read notification_channels from config and send to each
if [[ "$CHANNEL" == "--all" ]]; then
  if [[ ! -f "$CONFIG" ]]; then
    echo "Error: config not found at $CONFIG" >&2; exit 1
  fi
  CHANNELS=$(jq -r '.notification_channels[]' "$CONFIG" 2>/dev/null)
  [[ -z "$CHANNELS" ]] && { echo "Error: no notification_channels in config" >&2; exit 1; }
  for ch in $CHANNELS; do
    "$0" "$ch" "$RAW_MSG"
  done
  exit 0
fi

MSG="$(printf '══════════════════════════════════════\n🛡️  SHOOFLY ALERT\n──────────────────────────────────────\n%s\n══════════════════════════════════════' "$RAW_MSG")"

# Read credentials from config.json (never source .env as shell — F4)
TELEGRAM_BOT_TOKEN=$(jq -r '.telegram_bot_token // ""' "$CONFIG" 2>/dev/null || echo "")
TELEGRAM_CHAT_ID=$(jq -r '.telegram_chat_id // ""' "$CONFIG" 2>/dev/null || echo "")

# Pre-encode for safe interpolation (F2)
JSON_MSG=$(printf '%s' "$MSG" | jq -Rs .)
SAFE_OSA_MSG=$(printf '%s' "$MSG" | sed 's/\\/\\\\/g; s/"/\\"/g')

case "$CHANNEL" in
  telegram)
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      --data-urlencode "chat_id=${TELEGRAM_CHAT_ID}" \
      --data-urlencode "text=${MSG}" > /dev/null
    ;;
  whatsapp)
    command -v wacli >/dev/null && wacli send --to "$(jq -r .whatsapp_number "$CONFIG")" --message "$MSG"
    ;;
  openclaw_gateway)
    OPENCLAW_BIN=$(command -v openclaw 2>/dev/null || echo "/opt/homebrew/bin/openclaw")
    # Fire to OpenClaw control UI
    "$OPENCLAW_BIN" system event --text "$RAW_MSG" --mode now > /dev/null 2>&1
    # Also fire to Telegram if credentials exist
    CHAT_ID=$(jq -r '.telegram_chat_id // ""' "$CONFIG" 2>/dev/null || echo "")
    if [[ -n "$CHAT_ID" ]]; then
      "$OPENCLAW_BIN" message send --channel telegram --target "$CHAT_ID" --message "$RAW_MSG" > /dev/null 2>&1
    fi
    ;;
  terminal)
    echo "$MSG" >&2
    ;;
  macos)
    osascript -e "display notification \"$SAFE_OSA_MSG\" with title \"Shoofly 🪰\" sound name \"Basso\""
    ;;
esac

# Always log
jq -n -c --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg channel "$CHANNEL" --arg msg "$MSG" \
  '{ts:$ts,channel:$channel,msg:$msg}' >> "$HOME/.shoofly/logs/alerts.log"
